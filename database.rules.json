{
  "rules": {
    "typingStatus": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
